{
  "name": "pokemarket-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@pokemarket/web",
    "dev:mobile": "turbo dev --filter=@pokemarket/mobile",
    "build": "turbo build",
    "build:web": "turbo build --filter=@pokemarket/web",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-native-worklets": "0.5.1",
    "turbo": "^2.3.3",
    "typescript": "^5"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-test-renderer": "19.2.4"
  },
  "packageManager": "npm@10.9.0"
}

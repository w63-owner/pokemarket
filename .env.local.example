# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=pk_v1_your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=sk_v1_your-secret-key-here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Default country (ISO 3166-1 alpha-2) used when creating new Stripe Connect
# accounts. Defaults to FR if unset.
STRIPE_CONNECT_DEFAULT_COUNTRY=FR

# OpenAI (OCR)
OPENAI_API_KEY=

# Resend (Emails)
RESEND_API_KEY=
# Sender used for all transactional emails. Must be a verified domain in Resend
# in production. Use "onboarding@resend.dev" for local/staging if no domain is
# verified yet (capped at 100 emails/day, recipients limited to your Resend
# account email).
RESEND_FROM_EMAIL="PokeMarket <onboarding@resend.dev>"

# Push Notifications (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# RFC 8292 contact URI used by push services (Apple/Google/Mozilla) to reach
# us if our notifications misbehave. Must be a real mailto: or https:// URI.
VAPID_SUBJECT="mailto:contact@yourdomain.tld"

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

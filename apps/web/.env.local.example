# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=pk_v1_your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=sk_v1_your-secret-key-here

# MangoPay
# ─────────────────────────────────────────────────────────────────────────
# Sandbox: get these at https://hub.mangopay.com (Developers > API Keys)
# Production: provided by your MangoPay account manager after KYB approval
MANGOPAY_CLIENT_ID=
MANGOPAY_API_KEY=
# Sandbox = https://api.sandbox.mangopay.com
# Production = https://api.mangopay.com
MANGOPAY_BASE_URL=https://api.sandbox.mangopay.com
# HMAC SHA-256 secret used to verify inbound webhooks. Configure in dashboard
# (Developers > Webhooks > Secret) and copy the same value here.
MANGOPAY_WEBHOOK_SECRET=
# Created once during platform setup: a NaturalUser + Wallet that holds all
# escrow funds before they are transferred to the seller's wallet.
# See scripts/mangopay-smoke-test.ts and docs/MANGOPAY.md for setup.
MANGOPAY_PLATFORM_USER_ID=
MANGOPAY_PLATFORM_WALLET_ID=
# Same as MANGOPAY_CLIENT_ID — exposed to the browser for direct
# CardRegistration tokenisation (PCI SAQ-A pattern).
NEXT_PUBLIC_MANGOPAY_CLIENT_ID=

# OpenAI (OCR)
OPENAI_API_KEY=

# Resend (Emails)
RESEND_API_KEY=
# Sender used for all transactional emails. Must be a verified domain in Resend
# in production. Use "onboarding@resend.dev" for local/staging if no domain is
# verified yet (capped at 100 emails/day, recipients limited to your Resend
# account email).
RESEND_FROM_EMAIL="PokeMarket <onboarding@resend.dev>"

# Push Notifications (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# RFC 8292 contact URI used by push services (Apple/Google/Mozilla) to reach
# us if our notifications misbehave. Must be a real mailto: or https:// URI.
VAPID_SUBJECT="mailto:contact@yourdomain.tld"

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

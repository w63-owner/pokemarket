{
  "name": "@pokemarket/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-pre-install": "node -e \"const {execSync}=require('child_process');console.log('node:',process.version);console.log('cwd:',process.cwd());try{console.log('npm:',execSync('npm --version').toString().trim())}catch(e){console.log('npm check failed:',e.message)}\"",
    "dev": "expo start --dev-client",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prebuild": "expo prebuild --clean",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "update": "eas update",
    "update:preview": "eas update --branch preview --message",
    "update:production": "eas update --branch production --message"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@pokemarket/shared": "*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@sentry/react-native": "~6.20.0",
    "@shopify/flash-list": "1.7.6",
    "@stripe/stripe-react-native": "0.45.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.95.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-blur": "~14.1.5",
    "expo-camera": "~16.1.11",
    "expo-constants": "~17.1.7",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.0",
    "expo-image-manipulator": "~13.1.7",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.7",
    "expo-local-authentication": "~16.0.5",
    "expo-notifications": "~0.31.4",
    "expo-router": "~5.1.7",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~5.0.10",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~14.2.0",
    "lucide-react-native": "^1.14.0",
    "moti": "^0.30.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "13.13.2",
    "tailwind-merge": "^3.5.0",
    "victory-native": "^41.16.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "eslint": "^9",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}

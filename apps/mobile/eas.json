{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.19.0"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "channel": "development",
      "cache": {
        "key": "v1-dev-rn0.81-expo54"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging.pokemarket.app",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EAS_USE_CACHE": "1"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "channel": "preview",
      "cache": {
        "key": "v1-preview-rn0.81-expo54"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging.pokemarket.app",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EAS_USE_CACHE": "1"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "large"
      },
      "cache": {
        "key": "v1-prod-rn0.81-expo54"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://pokemarket.app",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EAS_USE_CACHE": "1",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a",
        "GRADLE_OPTS": "-Xmx8192m -XX:MaxMetaspaceSize=1024m"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6773838040"
      },
      "android": {
        "serviceAccountKeyPath": "../../secrets/play-store-service-account.json",
        "track": "internal"
      }
    }
  }
}

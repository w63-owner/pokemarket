{
  "expo": {
    "name": "PokeMarket",
    "slug": "pokemarket",
    "scheme": "pokemarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "app.pokemarket.mobile",
      "associatedDomains": ["applinks:pokemarket.app"],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "PokeMarket utilise l'appareil photo pour scanner vos cartes Pokémon et préremplir automatiquement vos annonces.",
        "NSPhotoLibraryUsageDescription": "PokeMarket accède à votre galerie pour ajouter des photos à vos annonces.",
        "NSFaceIDUsageDescription": "PokeMarket utilise Face ID pour sécuriser l'accès à votre compte."
      }
    },
    "android": {
      "package": "app.pokemarket.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E63946"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "pokemarket.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "PokeMarket utilise l'appareil photo pour scanner vos cartes Pokémon."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PokeMarket accède à votre galerie pour vos annonces."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "PokeMarket utilise Face ID pour sécuriser votre compte."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E63946"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.app.pokemarket",
          "enableGooglePay": true
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "note": "organization & project come from SENTRY_ORG / SENTRY_PROJECT env vars at build time; auth token from SENTRY_AUTH_TOKEN (EAS secret)."
        }
      ],
      "@sentry/react-native",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "TODO_SET_AFTER_EAS_INIT"
      }
    },
    "owner": "TODO_SET_EAS_OWNER"
  }
}
